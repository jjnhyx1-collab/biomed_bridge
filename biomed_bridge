  gap: 22px;
  font-size: 0.95rem;
  color: #3c4b52;
}

.nav-links a:hover {
  color: #006b70;
}

.hero {
  max-width: 1120px;
  margin: 0 auto;
  padding: 90px 24px 70px;
  display: grid;
  grid-template-columns: 1.3fr 0.7fr;
  gap: 36px;
  align-items: center;
}

.tag {
