  max-width: none;
  background: #eef8f8;
  padding-left: calc((100% - 1120px) / 2 + 24px);
  padding-right: calc((100% - 1120px) / 2 + 24px);
}

.section-title h2 {
  font-size: 2.2rem;
  margin-bottom: 22px;
  letter-spacing: -0.04em;
}

.section-description {
  max-width: 900px;
  color: #465a62;
  font-size: 1.05rem;
  margin-bottom: 34px;
}

.info-grid,
.project-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

.info-box,
.project-card,
.lab-note {
