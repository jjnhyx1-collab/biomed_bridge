  letter-spacing: 0.04em;
  margin-bottom: 12px;
}

.hero h1 {
  font-size: clamp(2.2rem, 5vw, 4.2rem);
  line-height: 1.15;
  letter-spacing: -0.05em;
  margin-bottom: 24px;
}

.subtitle {
